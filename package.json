{
  "name": "immersive-subs-prompter",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "node ./scripts/check-silent-catches.mjs && pnpm -r test",
    "lint:silent-catches": "node ./scripts/check-silent-catches.mjs",
    "typecheck": "pnpm -r typecheck",
    "build:desktop": "pnpm --filter @immersive-subs/desktop-app build",
    "build:extension": "pnpm --filter @immersive-subs/extension build",
    "test:desktop": "pnpm --filter @immersive-subs/desktop-app test:desktop",
    "test:extension": "pnpm --filter @immersive-subs/extension test"
  }
}
