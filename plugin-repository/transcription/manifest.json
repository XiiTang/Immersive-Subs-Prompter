{
  "id": "transcription",
  "author": {
    "id": "xiitang",
    "name": "XiiTang",
    "url": "https://github.com/XiiTang"
  },
  "version": "1.0.0",
  "displayName": "Speech Transcription",
  "description": "Transcribe active videos through the host transcription runtime.",
  "appCompatibility": {
    "minVersion": "1.0.0"
  },
  "entry": {
    "main": "main.js"
  },
  "permissions": [
    "settingsSchema",
    "transcriptionProvider",
    "transcriptionRuntime"
  ],
  "contributions": {
    "settings": [
      {
        "id": "transcription.settings",
        "title": "Speech Transcription",
        "schema": [
          {
            "id": "provider",
            "label": "Provider",
            "type": "select",
            "defaultValue": "whisper-api",
            "options": [
              {
                "value": "whisper-api",
                "label": "Whisper API"
              },
              {
                "value": "faster-whisper",
                "label": "Faster-Whisper"
              }
            ]
          },
          {
            "id": "baseUrl",
            "label": "API Base URL",
            "type": "string",
            "defaultValue": "https://api.openai.com/v1"
          },
          {
            "id": "apiKey",
            "label": "API Key",
            "type": "string",
            "defaultValue": ""
          },
          {
            "id": "model",
            "label": "Model",
            "type": "string",
            "defaultValue": "whisper-1"
          },
          {
            "id": "language",
            "label": "Language",
            "type": "string",
            "defaultValue": ""
          },
          {
            "id": "prompt",
            "label": "Prompt",
            "type": "textarea",
            "defaultValue": ""
          },
          {
            "id": "enableWordTimestamps",
            "label": "Word Timestamps",
            "type": "boolean",
            "defaultValue": false
          },
          {
            "id": "extraParamsJson",
            "label": "Extra API Params JSON",
            "type": "textarea",
            "defaultValue": "{}"
          },
          {
            "id": "ytDlpArgs",
            "label": "yt-dlp Audio Args",
            "type": "textarea",
            "defaultValue": ""
          },
          {
            "id": "fasterWhisperBinary",
            "label": "Faster-Whisper Binary",
            "type": "string",
            "defaultValue": "faster-whisper"
          },
          {
            "id": "fasterWhisperModel",
            "label": "Faster-Whisper Model",
            "type": "string",
            "defaultValue": "base"
          },
          {
            "id": "fasterWhisperModelDir",
            "label": "Faster-Whisper Model Directory",
            "type": "string",
            "defaultValue": ""
          },
          {
            "id": "fasterWhisperDevice",
            "label": "Faster-Whisper Device",
            "type": "select",
            "defaultValue": "cpu",
            "options": [
              {
                "value": "cpu",
                "label": "CPU"
              },
              {
                "value": "cuda",
                "label": "CUDA"
              }
            ]
          },
          {
            "id": "fasterWhisperVadFilter",
            "label": "Faster-Whisper VAD Filter",
            "type": "boolean",
            "defaultValue": true
          },
          {
            "id": "fasterWhisperVadThreshold",
            "label": "Faster-Whisper VAD Threshold",
            "type": "number",
            "defaultValue": 0.5
          },
          {
            "id": "fasterWhisperVadMethod",
            "label": "Faster-Whisper VAD Method",
            "type": "string",
            "defaultValue": ""
          },
          {
            "id": "fasterWhisperUseKim2",
            "label": "Faster-Whisper Kim2",
            "type": "boolean",
            "defaultValue": false
          }
        ]
      }
    ],
    "transcription": true
  },
  "package": {
    "url": "https://raw.githubusercontent.com/XiiTang/Immersive-Subs-Prompter/main/plugin-repository/transcription/1.0.0.usp-plugin",
    "sha256": "59d31a520ff782c5b1cec2813f72816206113ab3fc17e1b0c5ecccf17da11b13"
  }
}
