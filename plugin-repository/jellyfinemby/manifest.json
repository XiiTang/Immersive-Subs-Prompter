{
  "id": "jellyfinemby",
  "author": {
    "id": "xiitang",
    "name": "XiiTang",
    "url": "https://github.com/XiiTang"
  },
  "version": "1.0.0",
  "displayName": "Jellyfin / Emby",
  "description": "Connect Jellyfin or Emby browser pages as external media sources.",
  "appCompatibility": {
    "minVersion": "1.0.0"
  },
  "entry": {
    "main": "main.js"
  },
  "permissions": [
    "settingsSchema",
    "network",
    "mediaSourceAdapter"
  ],
  "contributions": {
    "settings": [
      {
        "id": "jellyfinemby.settings",
        "title": "Jellyfin / Emby",
        "schema": [
          {
            "id": "servers",
            "label": "Servers",
            "type": "serverList",
            "defaultValue": []
          }
        ]
      }
    ],
    "mediaSource": true
  },
  "package": {
    "url": "https://raw.githubusercontent.com/XiiTang/Immersive-Subs-Prompter/main/plugin-repository/jellyfinemby/1.0.0.usp-plugin",
    "sha256": "1222123815dc3626d92a0a740b983e5f75c7e21255727efdfb0ea925669920b8"
  }
}
