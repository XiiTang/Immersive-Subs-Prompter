{
  "name": "immersive-subs-prompter-desktop",
  "version": "0.0.1",
  "description": "Electron subtitle companion that syncs with the browser extension via WebSocket.",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run clean && npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc --project tsconfig.json",
    "build:preload": "tsc --project tsconfig.preload.json",
    "build:renderer": "vite build",
    "dev:renderer": "vite dev",
    "start": "npm run build && electron .",
    "clean": "rimraf dist",
    "clean:node-modules": "node scripts/cleanup-node-modules.js",
    "dist:win": "npm run build && npm run clean:node-modules && electron-builder --win",
    "dist:mac": "npm run build && npm run clean:node-modules && electron-builder --mac",
    "dist:linux": "npm run build && npm run clean:node-modules && electron-builder --linux",
    "dist:all": "npm run build && npm run clean:node-modules && electron-builder -mwl"
  },
  "keywords": [
    "electron",
    "subtitles",
    "yt-dlp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "active-win": "^8.2.1",
    "decompress": "^4.2.1",
    "iconv-lite": "^0.7.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/decompress": "^4.2.7",
    "@types/node": "^20.12.12",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^30.0.0",
    "electron-builder": "^26.0.12",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vue-tsc": "^1.8.27"
  },
  "build": {
    "appId": "com.example.immersivesubsprompter",
    "productName": "Immersive Subs Prompter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!**/node_modules/**/build/**",
      "!**/node_modules/**/*.map",
      "!**/node_modules/**/*.d.ts",
      "!**/node_modules/**/README*",
      "!**/node_modules/**/CHANGELOG*",
      "!**/node_modules/**/*.md",
      "!**/node_modules/**/.bin",
      "!**/node_modules/**/test/**",
      "!**/node_modules/**/tests/**",
      "!**/node_modules/**/spec/**",
      "!**/node_modules/**/docs/**",
      "!**/node_modules/**/*.tgz"
    ],
    "asarUnpack": [
      "node_modules/active-win/lib/binding/**"
    ],
    "extraResources": [
      {
        "from": "resources/yt-dlp",
        "to": "yt-dlp",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "win": {
      "signAndEditExecutable": false
    }
  }
}
