{
  "name": "universal-subtitle-desktop",
  "version": "0.1.0",
  "description": "Electron subtitle companion that syncs with the browser extension via WebSocket.",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run clean && tsc && npm run copy-static",
    "copy-static": "copyfiles -u 1 \"src/renderer/**/*.{html,css}\" dist/renderer",
    "start": "npm run build && electron .",
    "clean": "rimraf dist"
  },
  "keywords": [
    "electron",
    "subtitles",
    "yt-dlp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/ws": "^8.18.1",
    "copyfiles": "^2.4.1",
    "electron": "^30.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5"
  }
}
