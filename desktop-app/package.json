{
  "name": "immersive-subs-prompter-desktop",
  "version": "1.0.0",
  "description": "Electron subtitle companion that syncs with the browser extension via WebSocket.",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run clean && npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc --project tsconfig.json",
    "build:preload": "tsc --project tsconfig.preload.json",
    "typecheck:renderer": "vue-tsc --noEmit -p tsconfig.renderer.json",
    "build:renderer": "npm run typecheck:renderer && vite build",
    "dev:renderer": "vite dev",
    "test:renderer": "vitest run --project browser --project jsdom",
    "test:renderer:browser": "vitest run --project browser",
    "test:renderer:jsdom": "vitest run --project jsdom",
    "test:renderer:watch": "vitest --project browser --project jsdom",
    "start": "npm run build && electron-forge start",
    "clean": "rimraf dist",
    "clean:node-modules": "node scripts/cleanup-node-modules.cjs",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "dist:win": "npm run build && electron-forge make --platform=win32",
    "dist:mac": "npm run build && electron-forge make --platform=darwin",
    "dist:linux": "npm run build && electron-forge make --platform=linux"
  },
  "keywords": [
    "electron",
    "subtitles",
    "yt-dlp"
  ],
  "author": "sheixunixitang3@gmail.com",
  "license": "MIT",
  "dependencies": {
    "@chenglou/pretext": "0.0.5",
    "decompress": "4.2.1",
    "get-windows": "9.3.0",
    "iconv-lite": "0.7.2",
    "koffi": "2.15.6",
    "pinia": "3.0.4",
    "vue": "3.5.32",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@types/decompress": "4.2.7",
    "@types/node": "25.6.0",
    "@types/ws": "8.18.1",
    "@electron-forge/cli": "8.0.0-alpha.7",
    "@electron-forge/maker-deb": "8.0.0-alpha.7",
    "@electron-forge/maker-dmg": "8.0.0-alpha.7",
    "@electron-forge/maker-rpm": "8.0.0-alpha.7",
    "@electron-forge/maker-squirrel": "8.0.0-alpha.7",
    "@electron-forge/maker-zip": "8.0.0-alpha.7",
    "@electron-forge/plugin-auto-unpack-natives": "8.0.0-alpha.7",
    "@electron-forge/plugin-fuses": "8.0.0-alpha.7",
    "@electron/fuses": "2.1.1",
    "@vitest/browser-playwright": "4.1.4",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/test-utils": "2.4.6",
    "electron": "41.2.0",
    "jsdom": "29.0.2",
    "playwright": "1.59.1",
    "rimraf": "6.1.3",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "vue-tsc": "3.2.6"
  },
  "overrides": {
    "@mapbox/node-pre-gyp": "2.0.3",
    "node-gyp": "12.2.0",
    "make-fetch-happen": "15.0.5",
    "cacache": "20.0.4",
    "tar": "7.5.13"
  }
}
