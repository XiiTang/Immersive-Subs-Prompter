{
  "manifest_version": 3,
  "name": "Immersive Subs Prompter",
  "version": "0.0.1",
  "description": "Injects into major video sites, captures playback info, and relays it to the Immersive Subs Prompter desktop app.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "logger.js",
        "content-script.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Immersive Subs Prompter",
    "default_popup": "popup.html"
  }
}
