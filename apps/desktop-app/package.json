{
  "name": "@immersive-subs/desktop-app",
  "version": "1.0.0",
  "description": "Electron subtitle companion that syncs with the browser extension via WebSocket.",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @immersive-subs/contracts build && pnpm run build:app",
    "build:app": "pnpm run clean && pnpm run build:main && pnpm run build:preload && pnpm run build:renderer",
    "build:main": "tsc --project tsconfig.json",
    "build:preload": "tsc --project tsconfig.preload.json",
    "typecheck:main": "tsc --project tsconfig.json --noEmit",
    "typecheck:preload": "tsc --project tsconfig.preload.json --noEmit",
    "typecheck:renderer": "vue-tsc --noEmit -p tsconfig.renderer.json",
    "build:renderer": "pnpm run typecheck:renderer && vite build",
    "dev:renderer": "vite dev",
    "test": "pnpm run test:app",
    "test:app": "node ./scripts/run-desktop-tests.mjs",
    "test:desktop": "pnpm run test",
    "test:renderer:browser": "vitest run --project browser",
    "test:renderer:jsdom": "vitest run --project jsdom",
    "test:renderer:watch": "vitest --project browser --project jsdom",
    "start": "pnpm run build && electron-forge start .",
    "clean": "rimraf dist",
    "package": "pnpm run build && node ./scripts/run-forge-from-deploy.mjs package",
    "make": "pnpm run build && node ./scripts/run-forge-from-deploy.mjs make",
    "dist:win": "pnpm run build && node ./scripts/run-forge-from-deploy.mjs make --platform=win32",
    "dist:mac": "pnpm run build && node ./scripts/run-forge-from-deploy.mjs make --platform=darwin",
    "dist:linux": "pnpm run build && node ./scripts/run-forge-from-deploy.mjs make --platform=linux",
    "typecheck": "pnpm --filter @immersive-subs/contracts build && pnpm run typecheck:app",
    "typecheck:app": "pnpm run typecheck:main && pnpm run typecheck:preload && pnpm run typecheck:renderer"
  },
  "keywords": [
    "electron",
    "subtitles",
    "yt-dlp"
  ],
  "author": "sheixunixitang3@gmail.com",
  "license": "MIT",
  "dependencies": {
    "@chenglou/pretext": "0.0.7",
    "@immersive-subs/contracts": "workspace:*",
    "@lucide/vue": "1.17.0",
    "fflate": "^0.8.3",
    "get-windows": "9.3.0",
    "iconv-lite": "0.7.2",
    "pinia": "3.0.4",
    "reka-ui": "2.9.10",
    "vue": "3.5.35",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-deb": "7.11.2",
    "@electron-forge/maker-dmg": "7.11.2",
    "@electron-forge/maker-rpm": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron/fuses": "2.1.2",
    "@types/node": "25.6.2",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/browser-playwright": "4.1.8",
    "@vue/test-utils": "2.4.11",
    "electron": "42.4.0",
    "jsdom": "29.1.1",
    "lodash": "4.18.1",
    "playwright": "1.59.1",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.4"
  }
}
