{
  "name": "@immersive-subs/desktop-app",
  "version": "1.0.0",
  "description": "Electron subtitle companion that syncs with the browser extension via WebSocket.",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @immersive-subs/contracts build && pnpm --filter @immersive-subs/plugin-sdk build && pnpm run clean && pnpm run build:main && pnpm run build:preload && pnpm run build:renderer",
    "build:main": "tsc --project tsconfig.json",
    "build:preload": "tsc --project tsconfig.preload.json",
    "typecheck:renderer": "vue-tsc --noEmit -p tsconfig.renderer.json",
    "build:renderer": "pnpm run typecheck:renderer && vite build",
    "dev:renderer": "vite dev",
    "test": "node ./scripts/run-renderer-tests.mjs",
    "test:renderer": "node ./scripts/run-renderer-tests.mjs",
    "test:renderer:browser": "vitest run --project browser",
    "test:renderer:jsdom": "vitest run --project jsdom",
    "test:renderer:watch": "vitest --project browser --project jsdom",
    "word-list:normalize": "tsx src/main/plugins/official/wordLookup/wordListCli.ts",
    "start": "pnpm run build && electron-forge start . --app-path .",
    "clean": "rimraf dist",
    "clean:node-modules": "node scripts/cleanup-node-modules.cjs",
    "package": "pnpm run build && electron-forge package . --app-path .",
    "make": "pnpm run build && electron-forge make . --app-path .",
    "dist:win": "pnpm run build && electron-forge make . --app-path . --platform=win32",
    "dist:mac": "pnpm run build && electron-forge make . --app-path . --platform=darwin",
    "dist:linux": "pnpm run build && electron-forge make . --app-path . --platform=linux",
    "typecheck": "pnpm --filter @immersive-subs/contracts build && pnpm --filter @immersive-subs/plugin-sdk build && pnpm run build:main && pnpm run build:preload && pnpm run typecheck:renderer"
  },
  "keywords": [
    "electron",
    "subtitles",
    "yt-dlp"
  ],
  "author": "sheixunixitang3@gmail.com",
  "license": "MIT",
  "dependencies": {
    "@immersive-subs/contracts": "workspace:*",
    "@immersive-subs/plugin-sdk": "workspace:*",
    "@chenglou/pretext": "0.0.7",
    "decompress": "4.2.1",
    "get-windows": "9.3.0",
    "iconv-lite": "0.7.2",
    "koffi": "2.16.2",
    "pinia": "3.0.4",
    "vue": "3.5.34",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@types/decompress": "4.2.7",
    "@types/node": "25.6.2",
    "@types/ws": "8.18.1",
    "@electron-forge/cli": "7.11.1",
    "@electron-forge/maker-deb": "7.11.1",
    "@electron-forge/maker-dmg": "7.11.1",
    "@electron-forge/maker-rpm": "7.11.1",
    "@electron-forge/maker-squirrel": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.1",
    "@electron-forge/plugin-fuses": "7.11.1",
    "@electron/fuses": "2.1.1",
    "@vitest/browser-playwright": "4.1.5",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/test-utils": "2.4.10",
    "electron": "41.2.0",
    "jsdom": "29.1.1",
    "playwright": "1.59.1",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.8"
  }
}
