{
  "name": "@immersive-subs/extension",
  "version": "0.0.1",
  "private": true,
  "author": "sheixunixitang3@gmail.com",
  "scripts": {
    "typecheck": "pnpm --filter @immersive-subs/contracts build && tsc -p tsconfig.json --noEmit",
    "build": "pnpm run typecheck && pnpm run build:chrome && pnpm run build:firefox",
    "build:chrome": "tsx ./esbuild.config.ts chrome",
    "build:firefox": "tsx ./esbuild.config.ts firefox",
    "build:all": "pnpm run build:chrome && pnpm run build:firefox",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@immersive-subs/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "0.1.40",
    "@types/node": "25.6.0",
    "esbuild": "0.28.0",
    "jsdom": "29.0.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
