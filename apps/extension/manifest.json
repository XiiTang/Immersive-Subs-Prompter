{
  "manifest_version": 3,
  "name": "Immersive Subs Prompter",
  "version": "1.0.0",
  "description": "Captures playback info from major video sites and relays it to the Immersive Subs Prompter desktop app for immersive subtitle learning.",
  "author": "sheixunixitang3@gmail.com",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/content-script.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Immersive Subs Prompter",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}